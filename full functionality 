function calculateMonthlyGrowth(streams) {
  if (streams.length === 0) return 0;
  
  const totalGrowth = streams.reduce((sum, stream) => sum + stream.growth, 0);
  return Math.round(totalGrowth / streams.length * 100) / 100;
}

